generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  createdAt      DateTime  @default(now())
  examDate       DateTime?
  roadmapWeek    Int       @default(1)
  knowledgeLevel String    @default("beginner")

  sessions      Session[]
  topicProgress TopicProgress[]
  examResults   ExamResult[]
}

model ExamResult {
  id             String   @id @default(uuid())
  userId         String
  score          Float
  totalQuestions Int
  correctAnswers Int
  domainScores   Json
  completedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  createdAt DateTime @default(now())
  messages  Json     @default("[]")

  user User @relation(fields: [userId], references: [id])
}

model TopicProgress {
  id          String   @id @default(uuid())
  userId      String
  topic       String
  domain      String
  lastStudied DateTime @default(now())

  easyCorrect   Int @default(0)
  easyTotal     Int @default(0)
  mediumCorrect Int @default(0)
  mediumTotal   Int @default(0)
  hardCorrect   Int @default(0)
  hardTotal     Int @default(0)

  easyCompleted   Boolean @default(false)
  mediumCompleted Boolean @default(false)
  hardCompleted   Boolean @default(false)
  topicCompleted  Boolean @default(false)

  weakScore Float @default(0)

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, topic])
}